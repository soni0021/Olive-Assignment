# LLM provider keys (only what you intend to use)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# OpenRouter — one key gives access to 300+ models via OpenAI-compatible API
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=llm-observe

# LiteLLM proxy — used for Gemini / DeepSeek / Grok when OpenRouter isn't used.
LITELLM_MASTER_KEY=sk-litellm-local

# Worker image variant. WITH_NLP=1 bakes Presidio + en_core_web_lg into the
# worker image (~600MB build). Leave at 0 to ship regex-only redaction.
WITH_NLP=0

# SDK -> ingestion
OBSERVE_INGESTION_URL=http://localhost:8000/v1/logs
OBSERVE_BUFFER_SIZE=1000
OBSERVE_TIMEOUT_SECONDS=2.0

# Ingestion service
DATABASE_URL=postgresql+asyncpg://observe:observe@localhost:5432/observe
INGESTION_HOST=0.0.0.0
INGESTION_PORT=8000
LOG_LEVEL=INFO

# Web app
# Leave OBSERVE_API_KEY empty for local dev — the middleware treats unset/empty
# as open access. SET THIS to a real value before exposing the UI on a network.
OBSERVE_API_KEY=
NEXT_PUBLIC_DEFAULT_PROVIDER=openai
